// Generated by analista-sistema — Fase 5 (logical WHMCS model)
// Engine: MariaDB/MySQL (WHMCS core — module does NOT own these tables)
// Note: WHMCS uses int PKs; conventions below document logical usage by nextcloudsaas module.

Project work_nc_whmcs_logical {
  database_type: 'MariaDB'
  Note: 'Logical data model consumed by nextcloudsaas WHMCS module v3.1.7. No module-owned tables.'
}

Table tblclients {
  id int [pk, increment]
  email varchar [not null]
  firstname varchar
  lastname varchar
  Note: 'Provisioning emails sent to client email'
}

Table tblorders {
  id int [pk, increment]
  status varchar [note: 'Pending|Active|Cancelled|Fraud']
  userid int [not null, ref: > tblclients.id]
  Note: 'AcceptOrder called after successful ModuleCreate'
}

Table tblservers {
  id int [pk, increment]
  type varchar [note: 'nextcloudsaas']
  name varchar
  ipaddress varchar
  hostname varchar
  username varchar
  password varchar [note: 'WHMCS encrypted']
  accesshash varchar [note: 'SSH key path fallback']
  port int
  disabled tinyint
  Note: 'SSH target for manage.sh'
}

Table tblproducts {
  id int [pk, increment]
  servertype varchar [note: 'nextcloudsaas']
  configoption1 varchar [note: 'disk_quota_gb']
  configoption2 varchar [note: 'max_users']
  configoption3 varchar [note: 'enable_collabora yesno']
  configoption4 varchar [note: 'enable_talk yesno']
  configoption5 varchar [note: 'ssh_key_path']
  configoption6 varchar [note: 'client_prefix']
  configoption7 varchar [note: 'collabora_hostname override']
  configoption8 varchar [note: 'signaling_hostname override']
  configoption9 varchar [note: 'turn_hostname override']
}

Table tblhosting {
  id int [pk, increment]
  userid int [not null, ref: > tblclients.id]
  orderid int [ref: > tblorders.id]
  packageid int [not null, ref: > tblproducts.id]
  server int [not null, ref: > tblservers.id]
  domain varchar [note: 'Synced from Custom Field Domínio da Instância']
  domainstatus varchar [note: 'Pending|Active|Suspended|Terminated']
  username varchar [note: 'Always admin for Nextcloud']
  password varchar [note: 'NC admin password — WHMCS encrypted']
  notes text [note: 'NextcloudSaaS dns_check_start, dns_expired, auto_provisioned markers']
}

Table tblcustomfields {
  id int [pk, increment]
  type varchar [note: 'product']
  relid int [note: 'product id']
  fieldname varchar [note: 'Domínio da Instância | Client Name | Nextcloud URL | ...']
  fieldtype varchar
  required varchar
}

Table tblcustomfieldsvalues {
  id int [pk, increment]
  fieldid int [not null, ref: > tblcustomfields.id]
  relid int [not null, note: 'service id = tblhosting.id']
  value text
}

// Remote artifacts (not in WHMCS DB — documented for integration)
Table remote_instance {
  client_name varchar [pk, note: 'Directory under /opt/nextcloud-customers/']
  credentials_file varchar [note: '.credentials parse via Helper::parseCredentials']
  compose_file varchar [note: 'docker-compose.yml — HP_SHARED_KEY']
  Note: 'Logical entity on Nextcloud host via SSH'
}

Ref: tblhosting.packageid > tblproducts.id
Ref: tblhosting.server > tblservers.id
